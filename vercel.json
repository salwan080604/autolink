{
  "version": 2,
  "builds": [
    {
      "src": "Autolink/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "Autolink/wsgi.py"
    }
  ],
  "commands": {
    "build": "python manage.py collectstatic --noinput"
  }
}
